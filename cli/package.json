{
  "name": "workflowskill-cli",
  "version": "0.3.0",
  "description": "WorkflowSkill CLI — run workflow files from the command line",
  "author": "Matthew Cromer",
  "type": "module",
  "bin": {
    "workflowskill": "./dist/cli.mjs"
  },
  "scripts": {
    "build": "tsdown src/cli.ts --format esm --no-dts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint 'src/**/*.ts' 'test/**/*.ts'"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "dependencies": {
    "workflowskill": "file:../runtime",
    "@anthropic-ai/sdk": "^0.51.0",
    "@mozilla/readability": "^0.6.0",
    "linkedom": "^0.18.10",
    "picocolors": "^1.1.1",
    "turndown": "^7.2.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "@types/turndown": "^5.0.5",
    "eslint": "^10.0.1",
    "tsdown": "^0.20.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.0",
    "vitest": "^4.0.18"
  }
}
