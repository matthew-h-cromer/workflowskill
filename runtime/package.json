{
  "name": "workflowskill",
  "version": "0.4.0",
  "description": "WorkflowSkill runtime - execute declarative agent workflows",
  "author": "Matthew Cromer",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/matthew-h-cromer/workflowskill.git",
    "directory": "runtime"
  },
  "homepage": "https://github.com/matthew-h-cromer/workflowskill#readme",
  "bugs": {
    "url": "https://github.com/matthew-h-cromer/workflowskill/issues"
  },
  "type": "module",
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    }
  },
  "files": [
    "dist",
    "skill"
  ],
  "scripts": {
    "build": "tsdown src/index.ts --format esm --dts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint 'src/**/*.ts' 'test/**/*.ts'",
    "prepublishOnly": "npm run typecheck && npm run test && npm run lint && npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "workflowskill",
    "agentskill",
    "workflow",
    "agent",
    "automation"
  ],
  "license": "MIT",
  "dependencies": {
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.1",
    "tsdown": "^0.20.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.0",
    "vitest": "^4.0.18"
  }
}
